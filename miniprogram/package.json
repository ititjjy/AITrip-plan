{
  "name": "aitrip-miniprogram",
  "version": "0.1.0",
  "private": true,
  "description": "AITrip 微信小程序端 — Taro 4 + React + TypeScript",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "framework": "react"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "build:h5": "taro build --type h5",
    "dev:h5": "taro build --type h5 --watch",
    "postinstall": "weapp-tw patch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@tarojs/webpack5-prebundle": "4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/cli": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/react": "^18.3.18",
    "@types/webpack-env": "^1.18.5",
    "babel-preset-taro": "4.2.0",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.2.0",
    "postcss-pxtransform": "4.2.0",
    "sass": "1.77.8",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.6.2",
    "weapp-tailwindcss": "4.8.9",
    "webpack": "5.78.0"
  },
  "resolutions": {
    "sass": "1.77.8",
    "tailwindcss-config": "1.1.3",
    "chokidar": "^3.6.0"
  }
}
